# =============================================================================
# ExploreMY AI — Environment Variables (Production)
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to the repository.
# =============================================================================

# ── Node ────────────────────────────────────────────────────────────────────
NODE_ENV=production

# ── Database (PostgreSQL via Railway) ───────────────────────────────────────
DATABASE_URL="postgresql://user:password@host:5432/exploremy?schema=public"
DATABASE_URL_REPLICA="postgresql://user:password@replica-host:5432/exploremy?schema=public"
DIRECT_URL="postgresql://user:password@host:5432/exploremy?schema=public"

# ── Redis (Upstash) ─────────────────────────────────────────────────────────
REDIS_URL="redis://default:password@host:6379"
UPSTASH_REDIS_REST_URL="https://xxx.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your-token"

# ── Clerk (Authentication) ──────────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_live_xxx"
CLERK_SECRET_KEY="sk_live_xxx"
CLERK_WEBHOOK_SECRET="whsec_xxx"
CLERK_JWT_TEMPLATE="exploremy"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/explore"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# ── Google Maps Platform ────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-maps-api-key"
GOOGLE_MAPS_API_KEY="your-maps-api-key"
GOOGLE_MAPS_MAP_ID="your-map-id"

# ── OpenAI ──────────────────────────────────────────────────────────────────
OPENAI_API_KEY="sk-xxx"
OPENAI_MODEL="gpt-4o"
OPENAI_MAX_TOKENS=4096
OPENAI_TEMPERATURE=0.7

# ── Google Gemini ───────────────────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-key"
GEMINI_MODEL="gemini-2.5-flash"

# ── Supabase (Storage) ──────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://xxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJxxx"
SUPABASE_SERVICE_ROLE_KEY="eyJxxx"
SUPABASE_STORAGE_BUCKET="exploremy-media"

# ── Algolia (Search) ────────────────────────────────────────────────────────
NEXT_PUBLIC_ALGOLIA_APP_ID="xxx"
NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY="xxx"
ALGOLIA_ADMIN_API_KEY="xxx"
ALGOLIA_PLACES_INDEX="places"
ALGOLIA_USERS_INDEX="users"
ALGOLIA_TRIPS_INDEX="trips"

# ── Stripe (Payments) ───────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_live_xxx"
STRIPE_WEBHOOK_SECRET="whsec_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_xxx"
STRIPE_PRO_MONTHLY_PRICE_ID="price_xxx"
STRIPE_ENTERPRISE_MONTHLY_PRICE_ID="price_xxx"

# ── PostHog (Analytics) ─────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY="phc_xxx"
NEXT_PUBLIC_POSTHOG_HOST="https://us.posthog.com"

# ── Sentry (Error Tracking) ─────────────────────────────────────────────────
NEXT_PUBLIC_SENTRY_DSN="https://xxx.ingest.sentry.io/xxx"
SENTRY_AUTH_TOKEN="xxx"
SENTRY_ORG="exploremy"
SENTRY_PROJECT="web"

# ── API ─────────────────────────────────────────────────────────────────────
API_URL="https://api.exploremy.ai"
NEXT_PUBLIC_API_URL="https://api.exploremy.ai"
API_INTERNAL_KEY="internal-secret-key"

# ── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://exploremy.ai"
NEXT_PUBLIC_APP_NAME="ExploreMY AI"
NEXT_PUBLIC_APP_DESCRIPTION="Malaysia Intelligent Travel Operating System"

# ── Email (Resend) ──────────────────────────────────────────────────────────
RESEND_API_KEY="re_xxx"
EMAIL_FROM="ExploreMY AI <noreply@exploremy.ai>"

# ── Weather (OpenWeatherMap) ────────────────────────────────────────────────
OPENWEATHER_API_KEY="your-api-key"
