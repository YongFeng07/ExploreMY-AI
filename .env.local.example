# =============================================================================
# ExploreMY AI — Local Development Environment Variables
# =============================================================================
# Copy to .env.local and fill in dev values.
# =============================================================================

NODE_ENV=development

# ── Database (Local Docker Postgres) ────────────────────────────────────────
DATABASE_URL="postgresql://exploremy:exploremy@localhost:5432/exploremy_dev?schema=public"
DIRECT_URL="postgresql://exploremy:exploremy@localhost:5432/exploremy_dev?schema=public"

# ── Redis (Local Docker) ────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"
UPSTASH_REDIS_REST_URL="http://localhost:8079"
UPSTASH_REDIS_REST_TOKEN="dev-token"

# ── Clerk (Development Instance) ────────────────────────────────────────────
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="pk_test_xxx"
CLERK_SECRET_KEY="sk_test_xxx"
CLERK_WEBHOOK_SECRET="whsec_dev_xxx"
CLERK_JWT_TEMPLATE="exploremy-dev"
NEXT_PUBLIC_CLERK_SIGN_IN_URL="/sign-in"
NEXT_PUBLIC_CLERK_SIGN_UP_URL="/sign-up"
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL="/explore"
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL="/onboarding"

# ── Google Maps (Dev Key with localhost restriction) ────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-dev-api-key"
GOOGLE_MAPS_API_KEY="your-dev-api-key"

# ── OpenAI (Dev/Test Key) ───────────────────────────────────────────────────
OPENAI_API_KEY="sk-dev-xxx"
OPENAI_MODEL="gpt-4o"

# ── Google Gemini ───────────────────────────────────────────────────────────
GEMINI_API_KEY="your-dev-gemini-key"

# ── Supabase (Local/Dev Project) ────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="http://localhost:54321"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJxxx"
SUPABASE_SERVICE_ROLE_KEY="eyJxxx"

# ── Algolia (Dev Index) ─────────────────────────────────────────────────────
NEXT_PUBLIC_ALGOLIA_APP_ID="dev-app-id"
NEXT_PUBLIC_ALGOLIA_SEARCH_API_KEY="dev-search-key"
ALGOLIA_ADMIN_API_KEY="dev-admin-key"

# ── Stripe (Test Mode) ──────────────────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_xxx"
STRIPE_WEBHOOK_SECRET="whsec_test_xxx"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_xxx"

# ── PostHog (Dev Project) ──────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY="phc_dev_xxx"
NEXT_PUBLIC_POSTHOG_HOST="https://us.posthog.com"

# ── API (Local) ─────────────────────────────────────────────────────────────
API_URL="http://localhost:3001"
NEXT_PUBLIC_API_URL="http://localhost:3001"
API_INTERNAL_KEY="dev-internal-key"

# ── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_APP_NAME="ExploreMY AI (Dev)"

# ── Optional Dev Tools ──────────────────────────────────────────────────────
# PRISMA_LOG_QUERY=true
# DEBUG=exploremy:*
# ENABLE_API_MOCK=true
