{
  "name": "@exploremy/api",
  "version": "0.1.0",
  "private": true,
  "description": "ExploreMY AI — NestJS Backend API",
  "scripts": {
    "dev": "nest start --watch",
    "build": "nest build",
    "start": "node dist/main",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "lint:fix": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@clerk/clerk-sdk-node": "^5.0.0",
    "@exploremy/config": "workspace:*",
    "@exploremy/database": "workspace:*",
    "@exploremy/shared": "workspace:*",
    "@googlemaps/google-maps-services-js": "^3.4.0",
    "@nestjs/axios": "^3.1.2",
    "@nestjs/bullmq": "^10.2.3",
    "@nestjs/cache-manager": "^2.3.0",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/event-emitter": "^2.1.1",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/schedule": "^4.1.2",
    "@nestjs/swagger": "^8.1.0",
    "@nestjs/throttler": "^6.3.0",
    "@prisma/client": "^6.1.0",
    "@supabase/supabase-js": "^2.47.8",
    "@types/passport-jwt": "^4.0.1",
    "algoliasearch": "^5.17.1",
    "bcrypt": "^6.0.0",
    "bullmq": "^5.34.0",
    "cache-manager": "^6.3.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "compression": "^1.7.5",
    "cookie-parser": "^1.4.7",
    "dotenv": "^16.4.7",
    "express": "^4.21.1",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "multer": "^2.2.0",
    "openai": "^4.76.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pino": "^9.5.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "stripe": "^17.4.0",
    "svix": "^1.42.0",
    "uuid": "^11.0.3",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@exploremy/eslint-config": "workspace:*",
    "@exploremy/tsconfig": "workspace:*",
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.2.0",
    "@nestjs/testing": "^10.4.0",
    "@types/bcrypt": "^6.0.0",
    "@types/compression": "^1.7.5",
    "@types/cookie-parser": "^1.4.8",
    "@types/express": "^5.0.0",
    "@types/jest": "^29.5.14",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.10.0",
    "@types/passport": "^1.0.17",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.16.0",
    "jest": "^29.7.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^6.1.0",
    "source-map-support": "^0.5.21",
    "supertest": "^7.0.0",
    "ts-jest": "^29.2.5",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.7.2"
  }
}
