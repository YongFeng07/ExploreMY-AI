}

enum ReviewModerationStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum BusinessVerificationStatus {
  UNVERIFIED
  PENDING
  VERIFIED
  REJECTED
}

enum ContentReportReason {
  SPAM
  INAPPROPRIATE
  FAKE
  OFFENSIVE
  COPYRIGHT
  OTHER
}

enum ContentReportStatus {
  PENDING
  REVIEWED
  RESOLVED
  DISMISSED
}

enum WeekendPlanType {
  ONE_DAY
  TWO_DAY
  THREE_DAY
  FULL_WEEKEND
