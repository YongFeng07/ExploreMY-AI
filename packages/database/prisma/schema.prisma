// =============================================================================
// CORE USER MODELS
// =============================================================================

model User {
  id                  String      @id @default(uuid()) @db.Uuid
  clerkId             String      @unique @db.VarChar(255)
  email               String      @unique @db.VarChar(320)
  displayName         String      @db.VarChar(100)
  avatarUrl           String?     @db.VarChar(2048)
  bio                 String?     @db.VarChar(500)
  homeCity            String?     @db.VarChar(100)
  homeState           String?     @db.VarChar(100)
  preferredLanguage   String      @default("en") @db.VarChar(10)
  travelStyle         TravelStyle?
  dietaryPreferences  Json?
  accessibilityNeeds  Json?
  role                UserRole    @default(USER)
  isDeleted           Boolean     @default(false)
  deletedAt           DateTime?
  lastLoginAt         DateTime?
  createdAt           DateTime    @default(now()) @db.Timestamptz()
  updatedAt           DateTime    @updatedAt @db.Timestamptz()

  // Relations
  profile              Profile?
  reviews              Review[]
  photos               Photo[]
  favorites            Favorite[]
  favoriteLists        FavoriteList[]
  trips                Trip[]
  weekendPlans          WeekendPlan[]
  aiRecommendations    AIRecommendation[]
  searchHistory        SearchHistory[]
  preferences          UserPreferences?
  locationHistory      LocationHistory[]
  achievements         UserAchievement[]
  notifications        Notification[]
  businessAccounts     BusinessAccount[]
  subscriptions        Subscription[]
  socialPosts          SocialPost[]
  socialComments       SocialComment[]
  socialLikes          SocialLike[]
  followers            UserFollow[]       @relation("Following")
  following            UserFollow[]       @relation("Follower")
  contentReports       ContentReport[]     @relation("ReportedBy")
  couponRedemptions    CouponRedemption[]
  datePlans            DatePlan[]
  dateHistories        DateHistory[]
  travelGoals          TravelGoal[]
  contributions        Contribution[]
  coupleWalletsP1      CoupleWallet[]     @relation("CouplePartner1")
  coupleWalletsP2      CoupleWallet[]     @relation("CouplePartner2")
  groupWallets         GroupWallet[]
  helpfulMarks         HelpfulMark[]
  placeViews           PlaceView[]
  devices              UserDevice[]
  sessions             UserSession[]

  @@index([clerkId])
  @@index([email])
  @@index([role])
  @@index([isDeleted])
  @@index([createdAt])
  @@index([lastLoginAt])
  @@map("users")
}

model Profile {
  id                String    @id @default(uuid()) @db.Uuid
  userId            String    @unique @db.Uuid
  followersCount    Int       @default(0)
  followingCount    Int       @default(0)
  reviewsCount      Int       @default(0)
  photosCount       Int       @default(0)
  achievementsCount Int       @default(0)
  tripsCount        Int       @default(0)
  favoritesCount    Int       @default(0)
  hiddenGemsFound   Int       @default(0)
  level             Int       @default(1)
  xp                Int       @default(0)
  isVerified        Boolean   @default(false)
  isBusinessOwner   Boolean   @default(false)
  socialLinks       Json?
  travelStats       Json?
  createdAt         DateTime  @default(now()) @db.Timestamptz()
  updatedAt         DateTime  @updatedAt @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([level])
  @@index([xp])
  @@map("profiles")
}

model UserDevice {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid
  deviceToken     String    @db.VarChar(512)
  platform        String    @db.VarChar(20)     // "ios" | "android" | "web"
  isActive        Boolean   @default(true)
  lastUsedAt      DateTime  @default(now()) @db.Timestamptz()
  createdAt       DateTime  @default(now()) @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deviceToken])
  @@index([userId, isActive])
  @@map("user_devices")
}

model UserSession {
  id              String    @id @default(uuid()) @db.Uuid
  userId          String    @db.Uuid
  token           String    @unique @db.VarChar(512)
  ipAddress       String?   @db.VarChar(45)
  userAgent       String?   @db.VarChar(512)
  expiresAt       DateTime  @db.Timestamptz()
  createdAt       DateTime  @default(now()) @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("user_sessions")
}

// =============================================================================
// PLACE MODELS
// =============================================================================

model Place {
  id                   String        @id @default(uuid()) @db.Uuid
  googlePlaceId        String?       @unique @db.VarChar(255)
  slug                 String        @unique @db.VarChar(255)
  name                 String        @db.VarChar(255)
  description          String?       @db.Text
  category             PlaceCategory
  subcategory          String?       @db.VarChar(100)
  address              String?       @db.VarChar(500)
  city                 String?       @db.VarChar(100)
  state                String?       @db.VarChar(100)
  postcode             String?       @db.VarChar(10)
  country              String        @default("Malaysia") @db.VarChar(100)
  lat                  Float
  lng                  Float
  location             Unsupported("geometry(Point, 4326)")?
  phone                String?       @db.VarChar(20)
  website              String?       @db.VarChar(2048)
  email                String?       @db.VarChar(320)
  priceLevel           Int?          // 0=Free, 1=Inexpensive, 2=Moderate, 3=Expensive, 4=Very Expensive
  rating               Float         @default(0)
  reviewCount          Int           @default(0)
  photos               Json?         // Array of photo URLs (primary photos)
  openingHours         Json?         // Structured opening hours per day
  amenities            Json?         // WiFi, Parking, Halal, Wheelchair, etc.
  isHiddenGem          Boolean       @default(false)
  hiddenGemScore       Float         @default(0)
  isTrending           Boolean       @default(false)
  trendingScore        Float         @default(0)
  popularityScore      Float         @default(0)
  isClaimed            Boolean       @default(false)
  claimedByBusinessId  String?       @db.Uuid
  isPermanentlyClosed  Boolean       @default(false)
  metadata             Json?
  searchVector         Unsupported("tsvector")?
  embedding            Unsupported("vector(1536)")?  // OpenAI text-embedding-3-small
  createdAt            DateTime      @default(now()) @db.Timestamptz()
  updatedAt            DateTime      @updatedAt @db.Timestamptz()

  // Relations
  reviews               Review[]
  photosRelation        Photo[]
  favorites             Favorite[]
  tripStops             TripStop[]
  weekendPlanStops      WeekendPlanStop[]
  weekendRecommendations WeekendRecommendation[]
  routesOrigin          Route[]                 @relation("OriginPlace")
  routesDest            Route[]                 @relation("DestinationPlace")
  events                Event[]
  aiRecommendations     AIRecommendation[]
  searchHistory         SearchHistory[]
  locationHistory       LocationHistory[]
  claimedByBusiness     BusinessAccount?        @relation("ClaimedPlaces", fields: [claimedByBusinessId], references: [id], onDelete: SetNull)
  socialPosts           SocialPost[]
  views                 PlaceView[]
  dateActivities        DateActivity[]

  @@index([lat, lng])
  @@index([category])
  @@index([city, state])
  @@index([rating])
  @@index([rating, reviewCount])
  @@index([isHiddenGem, hiddenGemScore])
  @@index([isTrending, trendingScore])
  @@index([popularityScore])
  @@index([googlePlaceId])
  @@index([slug])
  @@index([isClaimed])
  @@index([isPermanentlyClosed])
  @@index([priceLevel])
  @@index([category, city])
  @@index([category, rating])
  @@map("places")
}

// =============================================================================
// REVIEW & PHOTO MODELS
// =============================================================================

model Review {
  id               String                 @id @default(uuid()) @db.Uuid
  userId           String                 @db.Uuid
  placeId          String                 @db.Uuid
  rating           Int                    // 1-5 stars
  title            String?                @db.VarChar(255)
  content          String?                @db.Text
  photos           Json?                  // Array of photo URLs attached to review
  visitDate        DateTime?              @db.Timestamptz()
  spendPerPerson   Float?
  tags             Json?                  // ["halal", "cheap", "romantic", etc.]
  isVerifiedVisit  Boolean                @default(false)
  helpfulCount     Int                    @default(0)
  moderationStatus ReviewModerationStatus @default(PENDING)
  moderatedBy      String?                @db.Uuid
  moderatedAt      DateTime?              @db.Timestamptz()
  createdAt        DateTime               @default(now()) @db.Timestamptz()
  updatedAt        DateTime               @updatedAt @db.Timestamptz()

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  place        Place         @relation(fields: [placeId], references: [id], onDelete: Cascade)
  helpfulMarks HelpfulMark[]
  photosRelation Photo[]

  @@unique([userId, placeId], name: "uq_review_user_place")
  @@index([placeId, rating])
  @@index([placeId, moderationStatus])
  @@index([placeId, createdAt])
  @@index([userId])
  @@index([rating])
  @@index([moderationStatus])
  @@index([createdAt])
  @@index([placeId, rating, createdAt])
  @@map("reviews")
}

model HelpfulMark {
  id        String   @id @default(uuid()) @db.Uuid
  reviewId  String   @db.Uuid
  userId    String   @db.Uuid
  createdAt DateTime @default(now()) @db.Timestamptz()

  review Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId], name: "uq_helpful_review_user")
  @@index([reviewId])
  @@map("helpful_marks")
}

model Photo {
  id                String                 @id @default(uuid()) @db.Uuid
  userId            String                 @db.Uuid
  placeId           String?                @db.Uuid
  reviewId          String?                @db.Uuid
  url               String                 @db.VarChar(2048)
  thumbnailUrl      String?                @db.VarChar(2048)
  caption           String?                @db.VarChar(500)
  locationLat       Float?
  locationLng       Float?
  metadata          Json?                  // EXIF data: camera, aperture, etc.
  isAIProcessed     Boolean                @default(false)
  aiTags            Json?                  // AI-generated tags: ["food:nasi-lemak", "ambience:cozy"]
  moderationStatus  PhotoModerationStatus  @default(PENDING)
  createdAt         DateTime               @default(now()) @db.Timestamptz()

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  place  Place?  @relation(fields: [placeId], references: [id], onDelete: SetNull)
  review Review? @relation(fields: [reviewId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([placeId])
  @@index([reviewId])
  @@index([moderationStatus])
  @@index([createdAt])
  @@map("photos")
}

// =============================================================================
// FAVORITE MODELS
// =============================================================================

model Favorite {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @db.Uuid
  placeId   String    @db.Uuid
  listId    String?   @db.Uuid
  notes     String?   @db.VarChar(500)
  createdAt DateTime  @default(now()) @db.Timestamptz()

  user  User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place         @relation(fields: [placeId], references: [id], onDelete: Cascade)
  list  FavoriteList? @relation(fields: [listId], references: [id], onDelete: SetNull)

  @@unique([userId, placeId], name: "uq_favorite_user_place")
  @@index([userId])
  @@index([placeId])
  @@index([listId])
  @@index([createdAt])
  @@map("favorites")
}

model FavoriteList {
  id          String     @id @default(uuid()) @db.Uuid
  userId      String     @db.Uuid
  name        String     @db.VarChar(200)
  description String?    @db.VarChar(500)
  isPublic    Boolean    @default(false)
  coverPhoto  String?    @db.VarChar(2048)
  placeCount  Int        @default(0)
  createdAt   DateTime   @default(now()) @db.Timestamptz()
  updatedAt   DateTime   @updatedAt @db.Timestamptz()

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  favorites Favorite[]

  @@index([userId])
  @@index([isPublic])
  @@index([createdAt])
  @@map("favorite_lists")
}

// =============================================================================
// TRIP PLANNING MODELS
// =============================================================================

model Trip {
  id               String     @id @default(uuid()) @db.Uuid
  userId           String     @db.Uuid
  title            String     @db.VarChar(255)
  description      String?    @db.Text
  coverPhoto       String?    @db.VarChar(2048)
  destinationCity  String?    @db.VarChar(100)
  destinationState String?    @db.VarChar(100)
  startDate        DateTime?  @db.Timestamptz()
  endDate          DateTime?  @db.Timestamptz()
  budget           Float?
  budgetCurrency   String     @default("MYR") @db.VarChar(3)
  travelStyle      TravelStyle?
  isAIGenerated    Boolean    @default(false)
  aiPrompt         String?    @db.Text
  aiModel          String?    @db.VarChar(50)
  status           TripStatus @default(DRAFT)
  collaborators    Json?      // [{ userId, role: "editor"|"viewer", joinedAt }]
  totalCost        Float?     // Computed sum of all stops + transport
  totalDistance    Float?     // Computed sum in meters
  carbonFootprint  Float?     // Computed sum in grams
  dayCount         Int        @default(0)
  isPublic         Boolean    @default(false)
  shareToken       String?    @unique @db.VarChar(64)
  viewCount        Int        @default(0)
  likeCount        Int        @default(0)
  createdAt        DateTime   @default(now()) @db.Timestamptz()
  updatedAt        DateTime   @updatedAt @db.Timestamptz()

  user    User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  days    TripDay[]
  posts   SocialPost[]

  @@index([userId])
  @@index([userId, status])
  @@index([status])
  @@index([shareToken])
  @@index([isPublic, likeCount])
  @@index([startDate, endDate])
  @@index([createdAt])
  @@map("trips")
}

model TripDay {
  id         String    @id @default(uuid()) @db.Uuid
  tripId     String    @db.Uuid
  dayNumber  Int
  date       DateTime? @db.Date
  notes      String?   @db.Text
  weather    Json?     // Cached weather data: { temp, condition, icon }
  createdAt  DateTime  @default(now()) @db.Timestamptz()

  trip  Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  stops TripStop[]

  @@unique([tripId, dayNumber], name: "uq_trip_day_number")
  @@index([tripId])
  @@map("trip_days")
}

model TripStop {
  id                       String        @id @default(uuid()) @db.Uuid
  tripDayId                String        @db.Uuid
  placeId                  String        @db.Uuid
  order                    Int
  startTime                DateTime?     @db.Timetz()
  endTime                  DateTime?     @db.Timetz()
  durationMinutes          Int?
  notes                    String?       @db.Text
  transportModeFromPrevious TransportMode? // How to get here from previous stop
  costEstimate             Float?
  distanceFromPrevious     Float?         // Meters from previous stop

  tripDay TripDay @relation(fields: [tripDayId], references: [id], onDelete: Cascade)
  place   Place   @relation(fields: [placeId], references: [id], onDelete: Cascade)

  @@index([tripDayId])
  @@index([tripDayId, order])
  @@index([placeId])
  @@map("trip_stops")
}

// =============================================================================
// ROUTE & TRANSPORT MODELS
// =============================================================================

model Route {
  id                     String        @id @default(uuid()) @db.Uuid
  originPlaceId          String        @db.Uuid
  destinationPlaceId     String        @db.Uuid
  transportMode          TransportMode
  polyline               String?       @db.Text   // Encoded polyline from Google Directions
  distanceMeters         Float?
  durationSeconds        Float?
  durationInTrafficSeconds Float?
  costEstimate           Float?
  currency               String        @default("MYR") @db.VarChar(3)
  carbonFootprintGrams   Float?
  waypoints              Json?         // Intermediate stops
  steps                  Json?         // Turn-by-turn instructions
  routeType              RouteType     @default(FASTEST)
  scenicScore            Float         @default(0)
  foodDensityScore       Float         @default(0)
  touristDensityScore    Float         @default(0)
  metadata               Json?
  expiresAt              DateTime?     @db.Timestamptz()
  createdAt              DateTime      @default(now()) @db.Timestamptz()

  origin           Place             @relation("OriginPlace", fields: [originPlaceId], references: [id], onDelete: Cascade)
  destination      Place             @relation("DestinationPlace", fields: [destinationPlaceId], references: [id], onDelete: Cascade)
  transportOptions TransportOption[]

  @@index([originPlaceId, destinationPlaceId])
  @@index([originPlaceId, destinationPlaceId, transportMode])
  @@index([expiresAt])
  @@index([routeType])
  @@map("routes")
}

model TransportOption {
  id              String        @id @default(uuid()) @db.Uuid
  routeId         String        @db.Uuid
  type            TransportMode
  provider        String?       @db.VarChar(100)  // "Grab", "RapidKL", "KTM", "AirAsia"
  price           Float?
  currency        String        @default("MYR") @db.VarChar(3)
  durationMinutes Int?
  departureTime   DateTime?     @db.Timestamptz()
  arrivalTime     DateTime?     @db.Timestamptz()
  bookingUrl      String?       @db.VarChar(2048)
  metadata        Json?         // Additional provider-specific data
  createdAt       DateTime      @default(now()) @db.Timestamptz()

  route Route @relation(fields: [routeId], references: [id], onDelete: Cascade)

  @@index([routeId])
  @@index([type])
  @@index([routeId, type])
  @@map("transport_options")
}

// =============================================================================
// GAMIFICATION MODELS
// =============================================================================

model Achievement {
  id          String @id @default(uuid()) @db.Uuid
  code        String @unique @db.VarChar(50)
  name        String @db.VarChar(100)
  description String @db.VarChar(500)
  icon        String @db.VarChar(100)
  category    String @db.VarChar(50)  // "food", "exploration", "social", "review", "trip"
  xpReward    Int    @default(0)
  tier        Int    @default(1)      // 1=Bronze, 2=Silver, 3=Gold, 4=Platinum
  isHidden    Boolean @default(false) // Secret achievement?
  criteria    Json   // { type, threshold, description }

  userAchievements UserAchievement[]

  @@index([category])
  @@map("achievements")
}

model UserAchievement {
  id            String    @id @default(uuid()) @db.Uuid
  userId        String    @db.Uuid
  achievementId String    @db.Uuid
  progress      Float     @default(0)     // 0.0 to 1.0
  isCompleted   Boolean   @default(false)
  completedAt   DateTime? @db.Timestamptz()
  notifiedAt    DateTime? @db.Timestamptz()
  createdAt     DateTime  @default(now()) @db.Timestamptz()

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  @@unique([userId, achievementId], name: "uq_user_achievement")
  @@index([userId, isCompleted])
  @@index([achievementId])
  @@map("user_achievements")
}

// =============================================================================
// NOTIFICATION MODEL
// =============================================================================

model Notification {
  id         String           @id @default(uuid()) @db.Uuid
  userId     String           @db.Uuid
  type       NotificationType
  title      String           @db.VarChar(255)
  body       String           @db.Text
  data       Json?            // { placeId, tripId, userId, deepLink, etc. }
  imageUrl   String?          @db.VarChar(2048)
  isRead     Boolean          @default(false)
  readAt     DateTime?        @db.Timestamptz()
  isActioned Boolean          @default(false)
  actionedAt DateTime?        @db.Timestamptz()
  expiresAt  DateTime?        @db.Timestamptz()
  createdAt  DateTime         @default(now()) @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([type])
  @@index([expiresAt])
  @@map("notifications")
}

// =============================================================================
// BUSINESS MODELS
// =============================================================================

model BusinessAccount {
  id                    String                     @id @default(uuid()) @db.Uuid
  userId                String                     @db.Uuid
  businessName          String                     @db.VarChar(255)
  businessType          String?                    @db.VarChar(100)
  registrationNumber    String?                    @unique @db.VarChar(50)
  phone                 String?                    @db.VarChar(20)
  email                 String?                    @db.VarChar(320)
  website               String?                    @db.VarChar(2048)
  description           String?                    @db.Text
  logoUrl               String?                    @db.VarChar(2048)
  verificationStatus    BusinessVerificationStatus @default(UNVERIFIED)
  verifiedAt            DateTime?                  @db.Timestamptz()
  subscriptionTier      SubscriptionPlan           @default(FREE)
  subscriptionExpiresAt DateTime?                  @db.Timestamptz()
  analytics             Json?
  createdAt             DateTime                   @default(now()) @db.Timestamptz()
  updatedAt             DateTime                   @updatedAt @db.Timestamptz()

  user             User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  claimedPlaces    Place[]           @relation("ClaimedPlaces")
  promotions       Promotion[]
  coupons          Coupon[]
  subscriptions    Subscription[]
  advertisingSlots AdvertisingSlot[]

  @@index([userId])
  @@index([verificationStatus])
  @@index([subscriptionTier])
  @@map("business_accounts")
}

model Subscription {
  id                   String             @id @default(uuid()) @db.Uuid
  userId               String             @db.Uuid
  businessId           String?            @db.Uuid
  plan                 SubscriptionPlan
  status               SubscriptionStatus
  stripeSubscriptionId String?            @unique @db.VarChar(255)
  stripeCustomerId     String?            @db.VarChar(255)
  currentPeriodStart   DateTime?          @db.Timestamptz()
  currentPeriodEnd     DateTime?          @db.Timestamptz()
  canceledAt           DateTime?          @db.Timestamptz()
  trialEndAt           DateTime?          @db.Timestamptz()
  metadata             Json?
  createdAt            DateTime           @default(now()) @db.Timestamptz()
  updatedAt            DateTime           @updatedAt @db.Timestamptz()

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  business BusinessAccount? @relation(fields: [businessId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([businessId])
  @@index([stripeSubscriptionId])
  @@index([stripeCustomerId])
  @@index([status])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

model AdvertisingSlot {
  id            String    @id @default(uuid()) @db.Uuid
  businessId    String    @db.Uuid
  name          String    @db.VarChar(200)
  slotType      String    @db.VarChar(50)  // "search_promoted", "home_banner", "category_featured"
  placeId       String?   @db.Uuid         // If promoting a specific place
  imageUrl      String?   @db.VarChar(2048)
  targetUrl     String?   @db.VarChar(2048)
  budget        Float?
  impressions   Int       @default(0)
  clicks        Int       @default(0)
  startDate     DateTime  @db.Timestamptz()
  endDate       DateTime  @db.Timestamptz()
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now()) @db.Timestamptz()
  updatedAt     DateTime  @updatedAt @db.Timestamptz()

  business BusinessAccount @relation(fields: [businessId], references: [id], onDelete: Cascade)

  @@index([businessId])
  @@index([slotType, isActive])
  @@index([startDate, endDate])
  @@map("advertising_slots")
}

model Promotion {
  id            String    @id @default(uuid()) @db.Uuid
  businessId    String    @db.Uuid
  placeId       String?   @db.Uuid
  title         String    @db.VarChar(255)
  description   String?   @db.Text
  discountType  String?   @db.VarChar(50)  // "percentage", "fixed", "bogo", "free_item"
  discountValue Float?
  promoCode     String?   @db.VarChar(50)
  termsAndConditions String? @db.Text
  startDate     DateTime  @db.Timestamptz()
  endDate       DateTime  @db.Timestamptz()
  isActive      Boolean   @default(true)
  redemptionCount Int     @default(0)
  metadata      Json?
  createdAt     DateTime  @default(now()) @db.Timestamptz()
  updatedAt     DateTime  @updatedAt @db.Timestamptz()

  business BusinessAccount @relation(fields: [businessId], references: [id], onDelete: Cascade)
  coupons  Coupon[]

  @@index([businessId])
  @@index([placeId])
  @@index([isActive])
  @@index([startDate, endDate])
  @@index([startDate, endDate, isActive])
  @@map("promotions")
}

// =============================================================================
// COUPON MODELS
// =============================================================================

model Coupon {
  id             String              @id @default(uuid()) @db.Uuid
  promotionId    String?             @db.Uuid
  businessId     String              @db.Uuid
  code           String              @unique @db.VarChar(50)
  discountType   String              @db.VarChar(50)   // "percentage", "fixed", "free_item"
  discountValue  Float
  minSpend       Float?
  maxDiscount    Float?
  usageLimit     Int?                                   // NULL = unlimited
  usedCount      Int                 @default(0)
  userLimit      Int                 @default(1)        // Max per user
  startDate      DateTime            @db.Timestamptz()
  endDate        DateTime            @db.Timestamptz()
  isActive       Boolean             @default(true)
  terms          String?             @db.Text
  createdAt      DateTime            @default(now()) @db.Timestamptz()
  updatedAt      DateTime            @updatedAt @db.Timestamptz()

  promotion   Promotion?           @relation(fields: [promotionId], references: [id], onDelete: SetNull)
  business    BusinessAccount      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  redemptions CouponRedemption[]

  @@index([code])
  @@index([businessId])
  @@index([promotionId])
  @@index([isActive, startDate, endDate])
  @@map("coupons")
}

model CouponRedemption {
  id               String    @id @default(uuid()) @db.Uuid
  couponId         String    @db.Uuid
  userId           String    @db.Uuid
  placeId          String?   @db.Uuid
  discountApplied  Float?
  createdAt        DateTime  @default(now()) @db.Timestamptz()

  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([couponId, userId], name: "uq_coupon_user")
  @@index([couponId])
  @@index([userId])
  @@index([createdAt])
  @@map("coupon_redemptions")
}

// =============================================================================
// EVENT MODEL
// =============================================================================

model Event {
  id          String    @id @default(uuid()) @db.Uuid
  placeId     String?   @db.Uuid
  name        String    @db.VarChar(255)
  description String?   @db.Text
  startDate   DateTime  @db.Timestamptz()
  endDate     DateTime? @db.Timestamptz()
  type        String?   @db.VarChar(100)   // "festival", "concert", "food_fair", "exhibition", "sports"
