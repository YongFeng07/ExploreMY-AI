  createdAt   DateTime  @default(now()) @db.Timestamptz()

  place Place? @relation(fields: [placeId], references: [id], onDelete: SetNull)

  @@index([placeId])
  @@index([startDate, endDate])
  @@index([type])
  // @@index([cityState(placeId)]) // TODO: Virtual index — needs materialized view or denormalization
  @@map("events")
}

// =============================================================================
// AI MODELS
// =============================================================================

model AIRecommendation {
  id           String                @id @default(uuid()) @db.Uuid
  userId       String                @db.Uuid
  type         AIRecommendationType
  prompt       String                @db.Text
  response     Json?                 // Structured AI response
  model        String?               @db.VarChar(50)     // "gpt-4o", "gemini-2.5-flash"
  tokensUsed   Int?
  costIncurred Float?
  latencyMs    Int?
