  parent   SocialComment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: SetNull)
  replies  SocialComment[] @relation("CommentReplies")

  @@index([postId])
  @@index([postId, createdAt])
  @@index([userId])
  @@index([parentId])
