  weekendPlanId String?              @db.Uuid             // If recommendation generated a weekend plan
  createdAt    DateTime              @default(now()) @db.Timestamptz()

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place? @relation(fields: [placeId], references: [id], onDelete: SetNull)
  weekendPlan WeekendPlan? @relation(fields: [weekendPlanId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, type])
  @@index([type])
  @@index([model])
  @@index([createdAt])
  @@map("ai_recommendations")
}

// =============================================================================
// SEARCH MODELS
