// =============================================================================
// WEEKEND PLANNER MODELS
// =============================================================================

model WeekendPlan {
  id                  String                @id @default(uuid()) @db.Uuid
  userId              String                @db.Uuid
  title               String                @db.VarChar(255)
  description         String?               @db.Text

  destination         String                @db.VarChar(255)
  destinationLat      Float
  destinationLng      Float
  startDate           DateTime              @db.Date
  endDate             DateTime              @db.Date
  planType            WeekendPlanType
  budget              Float
  budgetCurrency      String                @default("MYR") @db.VarChar(3)
  transportMode       TransportMode
  groupType           GroupType
  travelStyles        WeekendTravelStyle[]
  specialPreferences  SpecialPreference[]
  groupSize           Int                   @default(1)

  isAIGenerated       Boolean               @default(true)
  aiModel             String?               @db.VarChar(50)
  aiPrompt            String?               @db.Text
  aiTokensUsed        Int?
  generationLatencyMs Int?
  generationVersion   String?               @db.VarChar(20)

  weatherSnapshot     Json?

  status              TripStatus            @default(DRAFT)
  isPublic            Boolean               @default(false)
  shareToken          String?               @unique @db.VarChar(64)
  viewCount           Int                   @default(0)
  likeCount           Int                   @default(0)
  cloneCount          Int                   @default(0)

  totalCost           Float?
  totalDistance       Float?
  totalTravelTime     Int?
  totalStops          Int                   @default(0)
  hiddenGemCount      Int                   @default(0)

  createdAt           DateTime              @default(now()) @db.Timestamptz()
  updatedAt           DateTime              @updatedAt @db.Timestamptz()

  user              User                     @relation(fields: [userId], references: [id], onDelete: Cascade)
  days              WeekendPlanDay[]
  budgetItems       WeekendBudget[]
  routes            WeekendRoute[]
  recommendations   WeekendRecommendation[]
  optimizations     WeekendOptimization[]
  aiRecommendations AIRecommendation[]

  @@index([userId])
  @@index([userId, status])
  @@index([shareToken])
  @@index([destination])
  @@index([startDate, endDate])
  @@index([isPublic, likeCount])
  @@index([createdAt])
  @@map("weekend_plans")
}

model WeekendPlanDay {
  id              String    @id @default(uuid()) @db.Uuid
  weekendPlanId   String    @db.Uuid
  dayNumber       Int
  date            DateTime  @db.Date
  theme           String?   @db.VarChar(255)
  notes           String?   @db.Text

  weatherCondition  String?  @db.VarChar(50)
  weatherTempMin    Float?
  weatherTempMax    Float?
  weatherRainChance Float?

  dayTotalCost     Float?
  dayTotalDistance Float?
  dayTotalTime     Int?
  stopCount        Int       @default(0)

  createdAt       DateTime  @default(now()) @db.Timestamptz()

  weekendPlan WeekendPlan      @relation(fields: [weekendPlanId], references: [id], onDelete: Cascade)
  stops       WeekendPlanStop[]

  @@unique([weekendPlanId, dayNumber], map: "uq_weekend_day_number")
  @@index([weekendPlanId])
  @@map("weekend_plan_days")
}

model WeekendPlanStop {
  id              String       @id @default(uuid()) @db.Uuid
  weekendDayId    String       @db.Uuid
  placeId         String?      @db.Uuid
  order           Int

  startTime       String?      @db.VarChar(8)
  endTime         String?      @db.VarChar(8)
  durationMinutes Int

  placeName       String       @db.VarChar(255)
  placeCategory   StopCategory
  placeEmoji      String?      @db.VarChar(10)
  description     String?      @db.Text
  photoUrl        String?      @db.VarChar(2048)
  rating          Float?
  priceLevel      Int?

  transportModeFromPrev  TransportMode?
  distanceFromPrev       Float?
  travelTimeFromPrev     Int?
  transportCostFromPrev  Float?

  entryFee        Float?
  estimatedSpend  Float?

  isHiddenGem     Boolean     @default(false)
  isPhotoSpot     Boolean     @default(false)
  isAIGenerated   Boolean     @default(true)
  aiReasoning     String?     @db.Text

  isIndoor        Boolean     @default(false)
  crowdLevel      String?     @db.VarChar(20)
  rainSafe        Boolean     @default(true)

  isLocked        Boolean     @default(false)
  userNote        String?     @db.Text
  userRating      Int?

  createdAt       DateTime    @default(now()) @db.Timestamptz()

  weekendDay  WeekendPlanDay  @relation(fields: [weekendDayId], references: [id], onDelete: Cascade)
  place       Place?          @relation(fields: [placeId], references: [id], onDelete: SetNull)
  routesFrom  WeekendRoute[]  @relation("RouteFromStop")
  routesTo    WeekendRoute[]  @relation("RouteToStop")

  @@index([weekendDayId])
  @@index([weekendDayId, order])
  @@index([placeId])
  @@map("weekend_plan_stops")
}

model WeekendBudget {
  id              String       @id @default(uuid()) @db.Uuid
  weekendPlanId   String       @db.Uuid
  category        CostCategory
  label           String       @db.VarChar(100)

  estimatedCost   Float
  actualCost      Float?
  currency        String       @default("MYR") @db.VarChar(3)

  breakdown       Json?
  percentageOfTotal Float?

  notes           String?      @db.Text
  createdAt       DateTime     @default(now()) @db.Timestamptz()

  weekendPlan WeekendPlan @relation(fields: [weekendPlanId], references: [id], onDelete: Cascade)

  @@unique([weekendPlanId, category], map: "uq_weekend_budget_category")
  @@index([weekendPlanId])
  @@map("weekend_budgets")
}

model WeekendRoute {
  id              String              @id @default(uuid()) @db.Uuid
  weekendPlanId   String              @db.Uuid
  dayNumber       Int

  fromStopId      String?             @db.Uuid
  toStopId        String?             @db.Uuid
  transportMode   TransportMode

  polyline        String?             @db.Text
  distanceMeters  Float
  durationSeconds Float
  durationInTrafficSeconds Float?

  fuelCost        Float?
  tollCost        Float?
  parkingCost     Float?
  grabEstimate    Float?
  totalCost       Float?
  currency        String              @default("MYR") @db.VarChar(3)

  strategy        OptimizationStrategy @default(BALANCED)
  trafficLevel    String?             @db.VarChar(20)

  alternatives    Json?

  createdAt       DateTime            @default(now()) @db.Timestamptz()

  weekendPlan   WeekendPlan      @relation(fields: [weekendPlanId], references: [id], onDelete: Cascade)
  fromStop      WeekendPlanStop? @relation("RouteFromStop", fields: [fromStopId], references: [id], onDelete: SetNull)
  toStop        WeekendPlanStop? @relation("RouteToStop", fields: [toStopId], references: [id], onDelete: SetNull)

  @@index([weekendPlanId])
  @@index([weekendPlanId, dayNumber])
  @@index([fromStopId])
  @@index([toStopId])
  @@map("weekend_routes")
}

model WeekendRecommendation {
  id              String    @id @default(uuid()) @db.Uuid
  weekendPlanId   String    @db.Uuid
  stopId          String?   @db.Uuid
  dayNumber       Int?
  type            String    @db.VarChar(50)

  placeId         String?   @db.Uuid
  placeName       String    @db.VarChar(255)
  placeCategory   String?   @db.VarChar(100)
  description     String?   @db.Text
  photoUrl        String?   @db.VarChar(2048)
  rating          Float?
  estimatedCost   Float?
  currency        String    @default("MYR") @db.VarChar(3)

  relevanceScore  Float
  reasoning       String?   @db.Text

  isAccepted      Boolean   @default(false)
  isDismissed     Boolean   @default(false)

  createdAt       DateTime  @default(now()) @db.Timestamptz()

  weekendPlan WeekendPlan      @relation(fields: [weekendPlanId], references: [id], onDelete: Cascade)
  place       Place?           @relation(fields: [placeId], references: [id], onDelete: SetNull)

  @@index([weekendPlanId])
  @@index([stopId])
  @@index([isAccepted])
  @@map("weekend_recommendations")
}

model WeekendOptimization {
  id              String              @id @default(uuid()) @db.Uuid
  weekendPlanId   String              @db.Uuid

  strategy        OptimizationStrategy
  version         Int

  previousTotalDistance  Float?
  optimizedTotalDistance Float?
  distanceSaved          Float?
  previousTotalTime      Int?
  optimizedTotalTime     Int?
  timeSaved              Int?
  previousTotalCost      Float?
  optimizedTotalCost     Float?
  costSaved              Float?

  factorsConsidered Json?
  originalOrder     Json?
  optimizedOrder    Json?

  createdAt       DateTime            @default(now()) @db.Timestamptz()

  weekendPlan WeekendPlan @relation(fields: [weekendPlanId], references: [id], onDelete: Cascade)

  @@index([weekendPlanId])
  @@index([weekendPlanId, version])
  @@map("weekend_optimizations")
}

// =============================================================================
// 💕 AI DATING PLANNER — Complete Dating Platform Models
// =============================================================================

enum RelationshipStage {
  FIRST_DATE
  SECOND_DATE
  NEW_COUPLE
  LONG_TERM_COUPLE
  MARRIED_COUPLE
}

enum DateType {
  ROMANTIC
  ADVENTURE
  CAFE
  LUXURY
  FOOD_HUNT
  NATURE
  BEACH
  NIGHTLIFE
}

enum DateStatus {
  PLANNED
  ACTIVE
  COMPLETED
  CANCELLED
  RESCHEDULED
}

model DatePlan {
  id              String            @id @default(uuid()) @db.Uuid
  userId          String            @db.Uuid

  // Inputs
  city            String            @db.VarChar(255)
  budget          Float
  durationHours   Int               @default(4)
  transportMode   String            @default("DRIVING") @db.VarChar(30)
  relationshipStage RelationshipStage
  dateType        DateType

  // AI Outputs
  title           String            @db.VarChar(255)
  overview        String?           @db.Text
  aiModel         String?           @db.VarChar(50)
  isAIGenerated   Boolean           @default(false)

  // Timeline
  startTime       String?           @db.VarChar(10)
  endTime         String?           @db.VarChar(10)

  // Budget Breakdown (computed)
  travelCost      Float             @default(0)
  foodCost        Float             @default(0)
  activityCost    Float             @default(0)
  parkingCost     Float             @default(0)
  giftCost        Float             @default(0)
  totalCost       Float             @default(0)

  // AI Scoring
  romanceScore        Int           @default(0)
  conversationScore   Int           @default(0)
  privacyScore        Int           @default(0)
  budgetScore         Int           @default(0)
  photoOppScore       Int           @default(0)
  overallScore        Int           @default(0)

  // Special Features
  rainBackupPlan      String?       @db.Text
  indoorBackupPlan    String?       @db.Text
  trafficBackupPlan   String?       @db.Text
  sunsetTiming        String?       @db.VarChar(20)
  goldenHourTiming    String?       @db.VarChar(20)
  crowdLevel          String?       @db.VarChar(20)
  bestPhotoSpots      Json?

  // Route
  walkingRoute        Json?
  drivingRoute        Json?
  alternativeRoute    Json?

  // Metadata
  status              DateStatus    @default(PLANNED)
  createdAt           DateTime      @default(now()) @db.Timestamptz()
  updatedAt           DateTime      @updatedAt @db.Timestamptz()

  // Relations
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  activities      DateActivity[]
  scores          DateScore[]
  history         DateHistory[]

  @@index([userId])
  @@index([userId, status])
  @@index([city])
  @@map("date_plans")
}

model DateActivity {
  id              String            @id @default(uuid()) @db.Uuid
  datePlanId      String            @db.Uuid
  order           Int

  // Activity Details
  timeSlot        String            @db.VarChar(20)
  activityType    String            @db.VarChar(50)
  placeName       String            @db.VarChar(255)
  placeId         String?           @db.Uuid
  category        String?           @db.VarChar(50)
  description     String?           @db.Text

  // Timing
  suggestedArrival  String?         @db.VarChar(10)
  durationMinutes   Int             @default(60)
  travelTimeFromPrev Int?           // minutes from previous activity

  // Cost
  estimatedCost     Float           @default(0)
  currency          String          @default("MYR") @db.VarChar(3)

  // Enrichment
  photoUrl          String?         @db.VarChar(2048)
  rating            Float?
  address           String?         @db.VarChar(512)
  notes             String?         @db.Text
  isIndoor          Boolean         @default(false)
  isPhotoSpot       Boolean         @default(false)
  isBackupPlan      Boolean         @default(false)

  createdAt         DateTime        @default(now()) @db.Timestamptz()

  datePlan  DatePlan  @relation(fields: [datePlanId], references: [id], onDelete: Cascade)
  place     Place?    @relation(fields: [placeId], references: [id], onDelete: SetNull)

  @@index([datePlanId])
  @@index([datePlanId, order])
  @@map("date_activities")
}

model DateScore {
  id              String            @id @default(uuid()) @db.Uuid
  datePlanId      String            @db.Uuid

  category        String            @db.VarChar(50)
  score           Int
  maxScore        Int               @default(100)
  reasoning       String?           @db.Text
  tips            Json?

  createdAt       DateTime          @default(now()) @db.Timestamptz()

  datePlan  DatePlan  @relation(fields: [datePlanId], references: [id], onDelete: Cascade)

  @@index([datePlanId])
  @@index([datePlanId, category])
  @@map("date_scores")
}

model DateHistory {
  id              String            @id @default(uuid()) @db.Uuid
  datePlanId      String            @db.Uuid
  userId          String            @db.Uuid

  status          DateStatus
  actualStartTime String?           @db.VarChar(10)
  actualEndTime   String?           @db.VarChar(10)
  actualTotalCost Float?
  rating          Int?
  feedback        String?           @db.Text
  photos          Json?

  createdAt       DateTime          @default(now()) @db.Timestamptz()

  datePlan  DatePlan  @relation(fields: [datePlanId], references: [id], onDelete: Cascade)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([datePlanId])
  @@index([userId])
  @@index([userId, createdAt(sort: Desc)])
  @@map("date_history")
}

// =============================================================================
// 💰 TRAVEL WALLET — Savings Goals, Couple/Group Wallets, AI Coach
// =============================================================================

enum WalletType {
  SOLO
  COUPLE
  GROUP
}

enum GoalStatus {
  ACTIVE
  COMPLETED
  PAUSED
  CANCELLED
}

enum ContributionFrequency {
  DAILY
  WEEKLY
  MONTHLY
  ONE_TIME
}

model TravelGoal {
  id              String            @id @default(uuid()) @db.Uuid
  userId          String            @db.Uuid
  walletType      WalletType        @default(SOLO)

  // Goal Details
  tripName        String            @db.VarChar(255)
  destination     String            @db.VarChar(255)
  targetAmount    Float
  targetDate      DateTime          @db.Timestamptz()
  description     String?           @db.Text
  coverPhoto      String?           @db.VarChar(2048)

  // Progress Tracking
  currentSavings  Float             @default(0)
  remainingAmount Float
  progressPct     Float             @default(0)
  forecastDate    DateTime?         @db.Timestamptz()

  // AI Coach
  dailyTarget     Float?
  weeklyTarget    Float?
  monthlyTarget   Float?
  budgetFeasibility Float?
  affordabilityScore Int?

  // Travel Wishlist
  estimatedTripCost   Float?
  recommendedBudget   Float?
  accommodationEst    Float?
  transportEst        Float?
  foodEst             Float?
  activitiesEst       Float?

  // Metadata
  status          GoalStatus        @default(ACTIVE)
  currency        String            @default("MYR") @db.VarChar(3)
  isPublic        Boolean           @default(false)
  createdAt       DateTime          @default(now()) @db.Timestamptz()
  updatedAt       DateTime          @updatedAt @db.Timestamptz()

  // Relations
  user            User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  contributions   Contribution[]
  milestones      TravelMilestone[]
  coupleWallet    CoupleWallet?
  groupWallet     GroupWallet?

  @@index([userId])
  @@index([userId, status])
  @@index([walletType])
  @@map("travel_goals")
}

model Contribution {
  id              String            @id @default(uuid()) @db.Uuid
  goalId          String            @db.Uuid
  userId          String            @db.Uuid
  amount          Float
  frequency       ContributionFrequency @default(ONE_TIME)
  note            String?           @db.VarChar(500)
  createdAt       DateTime          @default(now()) @db.Timestamptz()

  goal    TravelGoal  @relation(fields: [goalId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@index([goalId, createdAt(sort: Desc)])
  @@index([userId])
  @@map("contributions")
}

model CoupleWallet {
  id              String            @id @default(uuid()) @db.Uuid
  goalId          String            @db.Uuid @unique
  partner1Id      String            @db.Uuid
  partner2Id      String            @db.Uuid

  // Combined Progress
  partner1Savings   Float           @default(0)
  partner2Savings   Float           @default(0)
  combinedSavings   Float           @default(0)
  monthlySavings    Float           @default(0)

  // Love + Travel
  loveProgress      Int             @default(0)
  travelReadiness   Int             @default(0)

  // Countdown
  daysUntilTrip     Int?
  milestone25       Boolean         @default(false)
  milestone50       Boolean         @default(false)
  milestone75       Boolean         @default(false)
  milestone100      Boolean         @default(false)

  createdAt         DateTime        @default(now()) @db.Timestamptz()
  updatedAt         DateTime        @updatedAt @db.Timestamptz()

  goal        TravelGoal  @relation(fields: [goalId], references: [id], onDelete: Cascade)
  partner1    User        @relation("CouplePartner1", fields: [partner1Id], references: [id], onDelete: Cascade)
  partner2    User        @relation("CouplePartner2", fields: [partner2Id], references: [id], onDelete: Cascade)

  @@index([partner1Id])
  @@index([partner2Id])
  @@map("couple_wallets")
}

model GroupWallet {
  id              String            @id @default(uuid()) @db.Uuid
  goalId          String            @db.Uuid @unique
  adminId         String            @db.Uuid
  groupName       String            @db.VarChar(255)

  // Members (JSON for flexibility — stores userId, name, avatar, contribution)
  members         Json              @default("[]")

  // Progress
  totalTarget     Float
  totalContributed Float            @default(0)
  remainingBalance Float
  memberCount     Int               @default(2)
  tripReadiness   Int               @default(0)

  // Leaderboard (JSON)
  leaderboard     Json?

  createdAt       DateTime          @default(now()) @db.Timestamptz()
  updatedAt       DateTime          @updatedAt @db.Timestamptz()

  goal    TravelGoal  @relation(fields: [goalId], references: [id], onDelete: Cascade)
  admin   User        @relation(fields: [adminId], references: [id], onDelete: Cascade)

  @@index([adminId])
  @@index([goalId])
  @@map("group_wallets")
}

model TravelMilestone {
  id              String            @id @default(uuid()) @db.Uuid
  goalId          String            @db.Uuid
  milestone       Int               // 25, 50, 75, 100
  title           String            @db.VarChar(255)
  badgeEmoji      String            @db.VarChar(10)
  unlockedAt      DateTime          @default(now()) @db.Timestamptz()

  goal    TravelGoal  @relation(fields: [goalId], references: [id], onDelete: Cascade)

  @@index([goalId])
  @@index([goalId, milestone])
  @@map("travel_milestones")
}

