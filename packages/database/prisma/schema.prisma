  REVIEW_REQUEST
  ACHIEVEMENT_UNLOCKED
  NEW_FOLLOWER
  TRIP_REMINDER
  PLACE_VERIFIED
  PROMOTION_AVAILABLE
  BUSINESS_REPLY
  SYSTEM
  SOCIAL_LIKE
  SOCIAL_COMMENT
  TRIP_INVITE
  FAVORITE_PRICE_DROP
  NEARBY_HIDDEN_GEM
  WEEKLY_DIGEST
}

enum SubscriptionPlan {
  FREE
  PRO
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
  INCOMPLETE_EXPIRED
  TRIALING
  UNPAID
  PAUSED
}

enum TravelStyle {
  BUDGET
  MID_RANGE
  LUXURY
  ADVENTURE
  FOODIE
  CULTURAL
  FAMILY
  SOLO
  BACKPACKER
}

enum AIRecommendationType {
  FOOD
  ATTRACTION
  ROUTE
  WEEKEND_PLAN
  FULL_TRIP
  HIDDEN_GEM
  TRENDING
}

enum RouteType {
  FASTEST
  CHEAPEST
  SCENIC
  TOURIST
  FOOD
}

enum UserRole {
