}

// =============================================================================
// USER PREFERENCES & PRIVACY
// =============================================================================

model UserPreferences {
  id                    String    @id @default(uuid()) @db.Uuid
  userId                String    @unique @db.Uuid
  dietaryRestrictions   Json?     // ["halal", "vegetarian", "gluten-free", "no-pork", ...]
  cuisinePreferences    Json?     // { malay: 0.8, chinese: 0.7, indian: 0.6, thai: 0.4, ... }
