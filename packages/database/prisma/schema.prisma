  budgetLevel           Int?      // 1=Budget, 2=Mid, 3=Premium, 4=Luxury
  preferredTransport    Json?     // ["mrt", "grab", "walking"]
  accessibility         Json?     // { wheelchairAccessible, hearingImpaired, visionImpaired }
  notificationSettings  Json?     // { push, email, sms, types: { ... } }
  privacySettings       Json?     // { shareLocation, shareProfile, shareActivity }
  aiPersonalizationEnabled Boolean @default(true)
  createdAt             DateTime  @default(now()) @db.Timestamptz()
  updatedAt             DateTime  @updatedAt @db.Timestamptz()

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_preferences")
}

// =============================================================================
// LOCATION HISTORY
// =============================================================================

model LocationHistory {
  id         String    @id @default(uuid()) @db.Uuid
  userId     String    @db.Uuid
  lat        Float
  lng        Float
  accuracy   Float?
  speed      Float?    // Meters per second
  heading    Float?    // Degrees from north
  altitude   Float?
  activity   String?   @db.VarChar(50)  // "still", "walking", "running", "driving", "cycling"
  placeId    String?   @db.Uuid         // Reverse-geocoded nearest place
  city       String?   @db.VarChar(100)
  state      String?   @db.VarChar(100)
  recordedAt DateTime  @default(now()) @db.Timestamptz()

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  place Place? @relation(fields: [placeId], references: [id], onDelete: SetNull)

  @@index([userId, recordedAt], map: "location_history_userId_recordedAt_idx")
  @@index([userId, recordedAt(sort: Desc)], map: "location_history_userId_recordedAt_desc_idx")
  @@index([recordedAt])
  @@index([placeId])
  @@map("location_history")
